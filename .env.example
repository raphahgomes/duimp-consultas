# ============================================================================
# DUIMP - Consultas — Variáveis de Ambiente
# ============================================================================
# Copie este arquivo para .env e preencha os valores.
# Em Docker: docker compose usa .env automaticamente.
# ============================================================================

# ── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-secreta-segura-com-50-ou-mais-caracteres
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1
USE_HTTPS_IN_PRODUCTION=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
# Exemplo atrás de proxy reverso: HTTP_X_FORWARDED_PROTO:https
SECURE_PROXY_SSL_HEADER=

# ── Banco de dados ────────────────────────────────────────────────────────
# Se DB_HOST estiver vazio, usa SQLite (bom para desenvolvimento local).
# Em Docker, docker-compose.yml sobrescreve DB_HOST=db automaticamente.
DB_NAME=botduimp
DB_USER=botduimp
DB_PASSWORD=botduimp_secret
DB_HOST=
DB_PORT=5433           # Porta 5433 no host → 5432 no container (evita conflito com PostgreSQL local)

# ── Redis / Celery ────────────────────────────────────────────────────────
# Local: redis://localhost:6379/0
# Docker: redis://redis:6379/0 (docker-compose.yml já sobrescreve)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Criptografia Fernet (chaves de acesso Portal Único) ────────────────────
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=cole-aqui-a-chave-fernet-gerada-pelo-comando-acima
